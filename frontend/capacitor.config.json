{
  "appId": "com.rentzy.app",
  "appName": "RentXY",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"]
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1e40af",
      "showSpinner": true,
      "spinnerColor": "#ffffff",
      "androidScaleType": "CENTER_CROP"
    }
  },
  "android": {
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
